text", "marks": [{"type": "italic", "attrs": {}}]}, {"text": " cross-tenant leakage; and org memories silently vanishing or leaking because the key was ambiguous. ", "type": "text"}, {"text": "Rule:", "type": "text", "marks": [{"type": "italic", "attrs": {}}]}, {"text": " memory retrieval uses a Turbopuffer ", "type": "text"}, {"text": "namespace wall", "type": "text", "marks": [{"type": "bold", "attrs": {}}]}, {"text": " (the stronger grade, not attribute-scoped filtering); the ", "type": "text"}, {"text": "namespace key is the card's ", "type": "text", "marks": [{"type": "bold", "attrs": {}}]}, {"text": "owner_scope", "type": "text", "marks": [{"type": "bold", "attrs": {}}, {"type": "code", "attrs": {}}]}, {"text": " identity", "type": "text", "marks": [{"type": "bold", "attrs": {}}]}, {"text": " — ", "type": "text"}, {"text": "user-id", "type": "text", "marks": [{"type": "code", "attrs": {}}]}, {"text": " for a user card, ", "type": "text"}, {"text": "org-id", "type": "text", "marks": [{"type": "code", "attrs": {}}]}, {"text": " for an org card — derived at projection and carried on the ", "type": "text"}, {"text": "memory.*", "type": "text", "marks": [{"type": "code", "attrs": {}}]}, {"text": " event (AD-11). Retrieval queries ", "type": "text"}, {"text": "{caller user namespace} ∪ {caller org namespace filtered by the AD-8 firewall}", "type": "text", "marks": [{"type": "bold", "attrs": {}}]}, {"text": ". Namespace-per-user is proven at scale (Turbopuffer runs 250M+ namespaces). Resolves OQ2. ", "type": "text"}, {"text": "[ASSUMPTION]", "type": "text", "marks": [{"type": "code", "attrs": {}}]}, {"text": " cost envelope confirmed in the knowledge fold-in.", "type": "text"}]}, {"type": "paragraph", "attrs": {"id": "hqruuqxkggap", "indent": 0}, "content": [{"text": "AD-8 — Consent binds at the mint boundary, not at the client compose.", "type": "text", "marks": [{"type": "bold", "attrs": {}}]}, {"text": " ", "type": "text"}, {"text": "Binds:", "type": "text", "mark